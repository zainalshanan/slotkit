{
  "name": "@thebookingkit/cli",
  "version": "0.1.2",
  "publishConfig": {
    "access": "public"
  },
  "description": "CLI for adding The Booking Kit components and running migrations",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "thebookingkit": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "thebookingkit",
    "booking",
    "scheduling",
    "cli"
  ],
  "license": "MIT"
}
